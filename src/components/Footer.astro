---
import logoIcon from '../assets/logos/PNG/Asset 30@4x.png';
import logoWordmark from '../assets/logos/PNG/Asset 38@4x.png';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer style="background: #005280; color: #ffffff;">

  <!-- Main content -->
  <div class="max-w-screen-2xl mx-auto px-6 lg:px-24 pt-14 pb-0">

    <!-- Top row: Brand left, Early Bird right -->
    <div class="flex flex-col lg:flex-row justify-between gap-16 pb-12" style="border-bottom: 1px solid rgba(255,255,255,0.12);">

      <!-- Brand -->
      <div class="max-w-sm">
        <a href={base} class="flex items-center gap-3 mb-8">
          <img src={logoIcon.src} alt="" aria-hidden="true" class="h-10 w-auto translate-y-1" />
          <img src={logoWordmark.src} alt="Kingsley Village" class="h-12 w-auto" />
        </a>
        <p class="text-sm leading-relaxed mb-7" style="color: rgba(255,255,255,0.55); max-width: 32ch;">
          49 luxury sectional title homes on South Africa's KZN North Coast. Secure estate living from R2.25M.
        </p>
        <a
          href="https://instagram.com/kingsley_living"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 text-xs tracking-widest uppercase transition-colors hover:text-[#F8C16F]"
          style="color: rgba(255,255,255,0.4);"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          @kingsley_living
        </a>
      </div>

      <!-- Early Bird -->
      <div class="lg:max-w-sm w-full" style="border: 1px solid rgba(248,193,111,0.3); padding: 1.75rem; background:rgba(0,0,0,0.15);">
        <p class="text-xs tracking-widest uppercase mb-4" style="color: #F8C16F;">Limited Offer — First 10 Buyers</p>
        <p class="mb-2" style="font-family:'Cormorant Garamond',serif; font-size: 2rem; line-height:1.1; color:#ffffff;">
          Save R200,000
        </p>
        <p class="text-sm mb-8" style="color: rgba(255,255,255,0.55);">
          R100k discount + R100k in transfer &amp; attorney fees waived.
        </p>
        <a href={`${base}contact`} class="btn-primary w-full text-center block">Register Interest</a>
      </div>
    </div>

    <!-- Bottom row: Nav + Contact -->
    <div class="flex flex-col lg:flex-row justify-between gap-12 py-8" style="border-bottom: 1px solid rgba(255,255,255,0.12);">

      <!-- Nav links -->
      <nav class="flex flex-wrap gap-x-10 gap-y-4">
        {[
          { href: `${base}units`,    label: 'Our Homes' },
          { href: `${base}location`, label: 'Location' },
          { href: `${base}invest`,   label: 'Investment' },
          { href: `${base}about`,    label: 'About' },
          { href: `${base}contact`,  label: 'Contact' },
        ].map(({ href, label }) => (
          <a href={href} class="text-sm transition-colors hover:text-[#F8C16F]" style="color: rgba(255,255,255,0.55);">{label}</a>
        ))}
      </nav>

      <!-- Contact inline -->
      <div class="flex flex-col sm:flex-row gap-6 sm:gap-10 text-sm" style="color: rgba(255,255,255,0.5);">
        <span>Kevin Edwards &mdash; Sales Director</span>
        <a href="tel:+27658883723" class="hover:text-[#F8C16F] transition-colors">+27 65 888 3723</a>
        <a href="mailto:kevin@nichedevelopments.co.za" class="hover:text-[#F8C16F] transition-colors break-all">kevin@nichedevelopments.co.za</a>
      </div>
    </div>

    <!-- Copyright bar -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 py-8 text-xs" style="color: rgba(255,255,255,0.3);">
      <p>© {year} Kingsley Village · Niche Developments · All rights reserved</p>
      <p>Prices correct at time of publication and subject to change without notice</p>
    </div>

  </div>
</footer>
